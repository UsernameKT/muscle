<div class="card shadow-sm mb-4">

  <div class="card-header d-flex justify-content-between align-items-center">
    <%= link_to "← 投稿一覧", posts_path, class: "btn btn-outline-secondary btn-sm" %>

    <% unless current_user&.guest_user? %>
      <div class="d-flex gap-2">
        <%= link_to "編集", edit_post_path(@post), class: "btn btn-outline-primary btn-sm" %>
        <%= button_to "削除", post_path(@post),
              method: :delete,
              form: { data: { turbo_confirm: "削除しますか？" } },
              class: "btn btn-outline-danger btn-sm" %>
      </div>
    <% end %>
  </div>

  <div class="card-body">

  <%= render "public/searches/form" %>


    
    <h2 class="fw-bold mb-3"><%= @post.title %><i class="fa-solid fa-fire-flame-curved"></i></h2>

    
    <div class="d-flex justify-content-between align-items-center mb-3">

  <div class="text-muted">
    投稿者：
    <%= link_to @post.user.name, user_path(@post.user), class: "text-decoration-none" %>
  </div>

  <% unless current_user&.guest_user? %>
    <%= render "public/relationships/follow_button", user: @post.user %>
  <% end %>

</div>


      <% unless current_user&.guest_user? %>
        <%= render "public/relationships/follow_button", user: @post.user %>
      <% end %>
    </div>

    
    <div class="mb-4">
      <%= simple_format(@post.body) %>
    </div>

    
    <div class="d-flex justify-content-between align-items-center">
      <div class="text-muted small">
        投稿日：<%= l @post.created_at, format: :short %>
      </div>

      <div class="d-flex gap-3">
        <%= render "public/favorites/favorite", post: @post %>
        💬 <%= @post.post_comments.count %>
      </div>
    </div>

  </div>
</div>

      <div class="mb-3">
          <%= link_to "← 投稿一覧に戻る", posts_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>

    
    <% unless current_user&.guest_user? %>
      <hr>
      <div class="d-flex gap-2">
        <%= link_to "編集", edit_post_path(@post), class: "btn btn-outline-primary" %>
        <%= link_to "削除",
                    @post,
                    data: { turbo_method: :delete, turbo_confirm: "削除しますか？" },
                    class: "btn btn-danger" %>
      </div>
    <% end %>
  </div>
</div>


<div class="card shadow-sm">
  <div class="card-body">
    <h5 class="fw-bold mb-3">💬 コメント</h5>

    <div class="mb-3">
      <%= render "public/post_comments/index", post: @post %>
    </div>

    <%= render "public/post_comments/form", post: @post, post_comment: @post_comment %>
  </div>
</div>
